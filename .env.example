# Runtime
APP_ENV=local
TZ=Asia/Singapore
LOG_LEVEL=INFO

# 授时来源：system(默认，用系统时钟) | http(读HTTPS的Date头) | ntp(需 pip install ntplib)
TIME_SOURCE=system
NTP_SERVER=pool.ntp.org
TIME_HTTP_URL=https://www.cloudflare.com

# Hermes / Feishu Gateway
HERMES_BASE_URL=http://127.0.0.1:18789
HERMES_AGENT_NAME=arxiv-research-agent
FEISHU_HOME_CHAT_ID=
FEISHU_ALLOWED_CHAT_IDS=
FEISHU_ALLOWED_USER_IDS=

# Optional Feishu webhook fallback (custom bot incoming webhook)
FEISHU_WEBHOOK_URL=
FEISHU_WEBHOOK_SECRET=
# 若自定义机器人开启「自定义关键词」安全校验，填入关键词（发送时自动注入卡片）
FEISHU_WEBHOOK_KEYWORD=

# 飞书自建应用（长连接接入群聊 @ 交互；在开放平台创建应用后获取）
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# 飞书多维表格论文库（Milestone 4）。创建一个多维表格取 app_token，
# 再运行 `python -m src.main base-init <app_token>` 得到 table_id。需应用有 bitable 权限。
FEISHU_BASE_APP_TOKEN=
FEISHU_BASE_TABLE_ID=

# Lark CLI
LARK_CLI_BIN=lark
LARK_CLI_TIMEOUT_SECONDS=20
LARK_CLI_DRY_RUN=false

# LLM
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=
LLM_API_KEY=
LLM_CHAT_MODEL=
LLM_EMBEDDING_MODEL=
LLM_TIMEOUT_SECONDS=60
# 云端无 embedding 时用本地 fastembed（首次会下载模型，之后离线）。留空则禁用本地 embedding。
# 例：BAAI/bge-small-en-v1.5（英文，~130MB，适合 arXiv）
LOCAL_EMBEDDING_MODEL=
# 命令理解：llm=工具调用 Agent（默认，需配置 LLM）；rule=纯关键词规则路由
AGENT_MODE=llm

# arXiv
ARXIV_API_BASE=https://export.arxiv.org/api/query
ARXIV_REQUEST_DELAY_SECONDS=3
ARXIV_MAX_RESULTS_PER_PROFILE=200

# Storage
SQLITE_PATH=./data/research_agent.sqlite3
CACHE_DIR=./data/cache
